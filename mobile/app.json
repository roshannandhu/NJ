{
  "expo": {
    "name": "NJ India",
    "slug": "nj-india",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "njindia",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.njindia.app"
    },
    "android": {
      "package": "com.njindia.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a1a"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
