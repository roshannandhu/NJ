# Example environment for the CLOUD deployment. Set these on the host (Railway/
# Render/etc.). The local desktop app sets NONE of these and keeps using SQLite
# with no login.

# Managed Postgres connection string (the host usually provides this).
DATABASE_URL=postgresql://user:password@host:5432/njindia

# Turn on login enforcement for all /api routes.
NJ_AUTH_REQUIRED=1

# Strong random secret for signing login tokens. Generate with e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
NJ_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Optional: token lifetime in seconds (default 604800 = 7 days).
# NJ_TOKEN_TTL_SECONDS=604800

# First-run admin account, created on startup if it doesn't exist.
NJ_BOOTSTRAP_ADMIN_USER=admin
NJ_BOOTSTRAP_ADMIN_PASSWORD=change-this-strong-password
